---
import { Image } from 'astro:assets';
import '../styles/global.css';
import adventurerPlate from '../assets/chatgpt-plate-adventurer.webp';
import outdoorPlate from '../assets/chatgpt-plate-outdoor.webp';
import portraitPlate from '../assets/chatgpt-plate-portrait.webp';
import veldmuisLogo from '../assets/veldmuis-logo.png';

const tickerItems = [
  'Senior software developer',
  'AI-native builder',
  'Tech lead',
  'DevOps tinkerer',
  'Full-stack builder',
  'Veldmuis maintainer',
  'Linux enthusiast',
  'Problem unraveller',
  'Feature architect',
];

const skills = [
  {
    title: 'Frontend',
    items: ['Angular', 'TypeScript', 'JavaScript', 'HTML', 'CSS', 'AI-assisted interfaces'],
  },
  {
    title: 'Backend',
    items: ['Kotlin', 'Spring Boot', 'C#', '.NET', 'Java', 'Python', 'Go', 'API design'],
  },
  {
    title: 'Systems',
    items: ['Linux', 'Shell', 'Arch packaging', 'Kubernetes', 'Ansible-style deployments', 'Veldmuis'],
  },
  {
    title: 'Data',
    items: ['PostgreSQL', 'MySQL', 'MS SQL', 'Oracle', 'DB2', 'Reporting systems'],
  },
  {
    title: 'Delivery',
    items: ['CI/CD', 'Bitbucket', 'Jenkins', 'Microservices', 'AI-enabled workflows', 'Feature delivery'],
  },
  {
    title: 'Leadership',
    items: ['Tech leadership', 'Upskilling', 'Pairing', 'Support', 'Direct communication', 'Product ownership'],
  },
];

const monthFormatter = new Intl.DateTimeFormat('en', {
  month: 'long',
  year: 'numeric',
});

const parseMonth = (value: string) => {
  const [year, month] = value.split('-').map(Number);
  return new Date(year, month - 1, 1);
};

const formatMonth = (value: string) => monthFormatter.format(parseMonth(value));

const formatDuration = (startValue: string, endValue?: string) => {
  const start = parseMonth(startValue);
  const end = endValue ? parseMonth(endValue) : new Date();
  const monthCount = Math.max(
    0,
    (end.getFullYear() - start.getFullYear()) * 12 + end.getMonth() - start.getMonth(),
  );
  const years = Math.floor(monthCount / 12);
  const months = monthCount % 12;
  const parts = [];

  if (years) {
    parts.push(`${years} ${years === 1 ? 'year' : 'years'}`);
  }

  if (months) {
    parts.push(`${months} ${months === 1 ? 'month' : 'months'}`);
  }

  return parts.join(' ') || 'Less than 1 month';
};

const experience = [
  {
    start: '2021-06',
    role: 'Senior Software Developer / Tech Lead',
    company: 'VAT IT',
    copy:
      'I lead, build, ship, support, and keep the delivery engine moving: microservices, CI/CD, Kotlin and Spring Boot backends, Angular frontends, and product work that has to survive real business weather.',
  },
  {
    start: '2019-11',
    end: '2021-05',
    role: 'Full Stack Engineer',
    company: 'Radixtrie',
    copy:
      'I worked on Data Aggregator / DBI, a reporting and visibility system that discovered servers and database instances, collected capacity and structure data, and helped surface places that needed repair.',
  },
  {
    start: '2015-03',
    end: '2019-03',
    role: 'Full Stack Engineer',
    company: 'Movation',
    copy:
      'I grew from junior developer into tech lead work, client-facing delivery, testing, support, database work, rollout pressure, and the practical art of keeping older systems useful.',
  },
].map((item) => ({
  ...item,
  period: `${formatMonth(item.start)} - ${item.end ? formatMonth(item.end) : 'Present'}`,
  duration: formatDuration(item.start, item.end),
}));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Ruanne Bornman is an AI-native senior software developer, tech lead, and maintainer of Veldmuis Linux."
    />
    <title>Ruanne Bornman | Developer Codex</title>
  </head>
  <body>
    <div class="site-shell">
      <aside class="marginalia marginalia-left" aria-hidden="true">
        <div class="marginal-frame"></div>
      </aside>

      <aside class="marginalia marginalia-right" aria-hidden="true">
        <div class="marginal-frame"></div>
      </aside>

      <div class="manuscript">
        <main>
          <section class="hero">
            <div class="hero-copy">
              <p class="eyebrow">The Developer Codex</p>
              <h1>Ruanne Bornman</h1>
              <p class="hero-lead">
                I am an AI-native senior software developer and tech lead who builds
                practical software, odd tools, Linux experiments, and future-facing
                systems with the machine turned all the way on.
              </p>
              <div class="hero-actions" aria-label="Primary actions">
                <a class="button" href="https://github.com/ruannnebornman" target="_blank" rel="noreferrer noopener">
                  View GitHub
                </a>
                <a class="button secondary" href="https://www.linkedin.com/in/ruannebornman" target="_blank" rel="noreferrer noopener">
                  LinkedIn
                </a>
                <a class="button secondary" href="mailto:work@ruannebornman.com">
                  Contact
                </a>
                <span class="button" aria-disabled="true" title="CV PDF coming soon">
                  CV coming soon
                </span>
              </div>
            </div>

            <aside class="portrait-panel" aria-label="Profile details">
              <div class="portrait-frame">
                <Image src={outdoorPlate} alt="Illuminated manuscript portrait of Ruanne outdoors" width={360} height={450} loading="eager" />
              </div>
              <div class="ledger">
                <span><strong>Role</strong><em>Senior Software Developer</em></span>
                <span><strong>Company</strong><em>VAT IT</em></span>
                <span><strong>Focus</strong><em>Tech lead</em></span>
                <span><strong>Based</strong><em>Midrand, South Africa</em></span>
                <span><strong>Languages</strong><em>English, Afrikaans</em></span>
              </div>
            </aside>

            <div class="ticker" aria-label="Role banner">
              <div class="ticker-track">
                {[...tickerItems, ...tickerItems].map((item) => <span>{item}</span>)}
              </div>
            </div>
          </section>

          <section class="section alt">
            <div class="section-header">
              <p class="eyebrow">Crown Project</p>
              <h2>I built and maintain Veldmuis Linux.</h2>
              <p>
                Veldmuis is an Arch-based KDE Plasma distribution with a signed
                package flow, a Calamares installer, and a systemd-boot install path.
                It is crafted in the veld, built in the open, and updated with a
                practical monthly rhythm.
              </p>
            </div>

            <div class="veldmuis-layout">
              <div class="crest" aria-label="Veldmuis mark">
                <div class="crest-logo">
                  <Image src={veldmuisLogo} alt="Veldmuis Linux logo" width={260} height={260} />
                </div>
                <div class="crest-caption">Crafted in the veld, built in the open.</div>
              </div>

              <div class="charter">
                <p>
                  New repo and ISO builds are intended around the first of each
                  month. Other updates happen when they are ready, which is a
                  reasonable way to run a small distro without pretending a calendar
                  is a compiler.
                </p>

                <div class="stat-grid" aria-label="Veldmuis details">
                  <div class="stat"><b>Desktop</b>KDE Plasma</div>
                  <div class="stat"><b>Base</b>Arch Linux</div>
                  <div class="stat"><b>Installer</b>Calamares</div>
                </div>

                <div class="button-row">
                  <a class="button" href="https://veldmuislinux.org/" target="_blank" rel="noreferrer noopener">
                    Visit Veldmuis
                  </a>
                  <a class="button secondary" href="https://github.com/ruannnebornman/veldmuis" target="_blank" rel="noreferrer noopener">
                    Source Repo
                  </a>
                  <a class="button secondary" href="https://github.com/ruannnebornman/veldmuis-website" target="_blank" rel="noreferrer noopener">
                    Website Repo
                  </a>
                </div>
              </div>
            </div>
          </section>

          <section class="section">
            <div class="section-header">
              <p class="eyebrow">Craft Inventory</p>
              <h2>Things I can reliably bring to the table.</h2>
              <p>
                My work sits somewhere between product delivery, tech leadership,
                modern service architecture, AI-assisted building, frontend surfaces,
                database wrangling, and the occasional Linux detour with a release
                pipeline.
              </p>
            </div>

            <div class="skill-grid">
              {skills.map((group) => (
                <section class="skill-group">
                  <h3>{group.title}</h3>
                  <div class="chip-list">
                    {group.items.map((item) => <span class="chip">{item}</span>)}
                  </div>
                </section>
              ))}
            </div>
          </section>

          <section class="section alt">
            <div class="section-header">
              <p class="eyebrow">Chronicle</p>
              <h2>I like leading, building, pairing, and finding the story in old systems.</h2>
              <p>
                I am direct, open to correction, and happiest around people who can
                challenge an idea without turning the room into theatre.
              </p>
            </div>

            <div class="chronicle">
              {experience.map((item) => (
                <article class="entry">
                  <div class="entry-date">
                    <time>{item.period}</time>
                    <span data-duration-start={item.start} data-duration-end={item.end}>{item.duration}</span>
                  </div>
                  <div>
                    <h3>{item.role}</h3>
                    <p><strong>{item.company}</strong></p>
                    <p>{item.copy}</p>
                  </div>
                </article>
              ))}
            </div>
          </section>

          <section class="section">
            <div class="github-portal">
              <div>
                <p class="eyebrow">Public Work Archive</p>
                <h2>GitHub is the shelf.</h2>
                <p>
                  I am not maintaining a museum catalogue here. My GitHub is where
                  the tools, experiments, distro work, scripts, and useful oddities
                  live as they change.
                </p>
              </div>
              <a class="button" href="https://github.com/ruannnebornman" target="_blank" rel="noreferrer noopener">
                Open GitHub
              </a>
            </div>
          </section>

          <section class="section alt">
            <div class="about-layout">
              <div class="about-copy">
                <p class="eyebrow">About</p>
                <h2>Useful, a little strange, and built with the future switched on.</h2>
                <p>
                  I love AI. Not as a footnote, not as a secret productivity trick,
                  and definitely not as something to apologize for. I build with it
                  in the loop, on purpose, because the future is already here and I
                  would rather be early than polite about it.
                </p>
                <p>
                  Give me a team, an awkward legacy system, a half-described product
                  problem, or a Linux idea that has wandered too far into the grass,
                  and I will bring the maps, the tools, the prompts, the code, and
                  the stubborn joy of making the whole thing move.
                </p>
              </div>
              <div class="plate-gallery" aria-label="Illuminated portrait plates">
                <figure class="plate-card plate-card-large">
                  <Image src={adventurerPlate} alt="Illuminated manuscript portrait of Ruanne in a futuristic adventurer style" width={450} height={562} loading="lazy" />
                </figure>
                <figure class="plate-card">
                  <Image src={portraitPlate} alt="Illuminated manuscript portrait of Ruanne Bornman" width={450} height={562} loading="lazy" />
                </figure>
              </div>
            </div>
          </section>

          <section class="section contact-section">
            <div class="contact-panel">
              <div>
                <p class="eyebrow">Sealed Letter</p>
                <h2>Talk to me.</h2>
                <p>
                  The useful doors are here: email, GitHub, LinkedIn, and eventually
                  a downloadable CV once the final PDF is ready.
                </p>
              </div>
              <div class="button-row">
                <a class="button" href="mailto:work@ruannebornman.com">Email</a>
                <a class="button secondary" href="https://www.linkedin.com/in/ruannebornman" target="_blank" rel="noreferrer noopener">
                  LinkedIn
                </a>
                <span class="button" aria-disabled="true" title="CV PDF coming soon">CV coming soon</span>
              </div>
            </div>
          </section>
        </main>
      </div>

      <footer class="site-footer">
        <p>Ruanne Bornman. Senior Software Developer. Veldmuis maintainer.</p>
      </footer>
    </div>
    <script is:inline>
      const formatLiveDuration = (startValue, endValue) => {
        const parseMonth = (value) => {
          const [year, month] = value.split('-').map(Number);
          return { year, month: month - 1 };
        };
        const start = parseMonth(startValue);
        const now = new Date();
        const end = endValue
          ? parseMonth(endValue)
          : { year: now.getFullYear(), month: now.getMonth() };
        const monthCount = Math.max(0, (end.year - start.year) * 12 + end.month - start.month);
        const years = Math.floor(monthCount / 12);
        const months = monthCount % 12;
        const parts = [];

        if (years) {
          parts.push(`${years} ${years === 1 ? 'year' : 'years'}`);
        }

        if (months) {
          parts.push(`${months} ${months === 1 ? 'month' : 'months'}`);
        }

        return parts.join(' ') || 'Less than 1 month';
      };

      document.querySelectorAll('[data-duration-start]').forEach((item) => {
        item.textContent = formatLiveDuration(item.dataset.durationStart, item.dataset.durationEnd);
      });
    </script>
  </body>
</html>
